{
  "name": "ledgerguard-api",
  "version": "1.0.0",
  "description": "Finance Data Processing and Access Control Backend",
  "private": true,
  "scripts": {
    "dev": "npm run dev:nest",
    "dev:nest": "tsx watch --tsconfig tsconfig.nest.json src/main.ts",
    "build": "npm run build:nest",
    "build:nest": "tsc -p tsconfig.nest.json --noEmit",
    "build:azure": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --outfile=dist/main.js --tsconfig=tsconfig.nest.json",
    "postinstall": "prisma generate && npm run build:azure",
    "start": "node dist/main.js",
    "start:nest": "tsx --tsconfig tsconfig.nest.json src/main.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest --runInBand tests/api.integration.test.ts",
    "check": "npm run lint && npm run test && npm run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm run db:up && npm run prisma:migrate -- --name init && npm run prisma:generate && npm run prisma:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "ledgerguard",
    "finance",
    "backend",
    "nestjs",
    "prisma",
    "postgresql",
    "jwt",
    "rbac",
    "swagger",
    "audit-log",
    "rate-limit"
  ],
  "author": "hp",
  "license": "MIT",
  "type": "commonjs",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-dist": "^5.32.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prisma": "^6.8.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
